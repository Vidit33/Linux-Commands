////making the Rpi, as static
go into /etc/dhcpcd.conf

interface wlan0
static ip_address=192.168.1.50/24
static routers=192.168.1.1
static domain_name_servers=8.8.8.8

paste this code and then reboot

//recording of esp32p4 with RPI
// 1. To check whether the esp is connected to Rpi
      lsusb
//2. To check whether the serial device port of RPI is connected to the esp32 or not
     ls /dev/ttyACM*
//3. echoing the port that my esp32p4 is connected with Rpi. it is connected to the ttyACM0 port
       stty -F /dev/ttyACM0 raw -echo
//4. start to put the data into a file(For Raw Data)
     cat /dev/ttyACM0 > audio.raw
//5. playing the file in RPI
     ffplay -f s32le -ar 48000 -ac 1 audio.raw

